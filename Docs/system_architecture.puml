' ============================================================================
' EXTENSION 7: MAML META-LEARNING
' ============================================================================
package "MAML Meta-Learning (Ext 7)" <<Rectangle>> #FBE9E7 {
  class MamlPolicy <<(P,#BF360C) nn.Module>> {
    obs_dim / num_actions / hidden_size
    .. Actor ..
    Linear -> Tanh -> Linear -> Tanh -> Linear
    .. Critic ..
    Linear -> Tanh -> Linear -> Tanh -> Linear(1)
    --
    + forward(obs) : (action_logits, value)
    + get_action(obs) : (action, log_prob, value)
    + inner_adapt(support_data, inner_lr, inner_steps) : MamlPolicy
    + compute_meta_loss(tasks, inner_lr, inner_steps) : tensor
    + compute_ppo_loss(obs, actions, returns, advantages) : dict
    .. Key ..
    torch.autograd.grad(create_graph=True)
    for differentiable inner adaptation
  }

  class MAMLTrainer <<(P,#BF360C)>> {
    meta_policy : MamlPolicy
    meta_optimizer : Adam
    replay_manager : ReplayBufferManager
    --
    + meta_train(iterations, tasks_per_batch, inner_lr, inner_steps) : dict
    + adapt_to_player(player_id, num_inner_steps) : MamlPolicy
    + evaluate_adaptation(player_id, max_steps, inner_lr) : dict
    + save_meta_model(path) / load_meta_model(path)
    --
    - sample_tasks(num_tasks) : list[PlayerTask]
    .. Key Metric ..
    Query loss at 0,1,2,3 inner steps
    Adaptation in 2-3 gradient steps
  }

  class "maml_data_utils" as MAMLDataUtils <<(P,#BF360C) Module>> {
    + compute_returns(rewards, dones, gamma) : ndarray
    + compute_gae(rewards, values, dones, gamma, lam) : ndarray
    + replay_to_tasks(replay_mgr, min_episodes, fraction) : list
    .. PlayerTask Dataclass ..
    support_{obs, actions, rewards, dones}
    query_{obs, actions, rewards, dones}
    + to_tensors(gamma) : dict {torch tensors}
  }

  class "train_maml.py" as TrainMAMLScript <<(P,#BF360C) Script>> {
    + meta_train : 5000 outer iterations
    + adapt --player-id X : fast adaptation
    + evaluate --player-id X : step-by-step loss
    + stats : player data overview
  }
}

