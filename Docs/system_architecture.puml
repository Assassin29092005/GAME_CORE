  }

  class "train_hierarchical.py" as TrainHierScript <<(P,#FF9800) Script>> {
    + phase_a_pretrain_tactician (200k)
    + phase_b_train_strategist (100k)
    + phase_c_joint_finetune (200k)
  }

  class "train_transfer.py" as TrainTransferScript <<(P,#FF9800) Script>> {
    + train_base
    + train_player --player-id <id>
    + stats
  }

  class "infer.py" as InferScript <<(P,#FF9800) Script>> {
    + infer_flat (standard PPO)
    + infer_hierarchical (strategist+tactician)
    + infer_transfer (per-player model)
    .. Extension 8 ..
    + infer_irl (IRL-augmented obs)
    .. Extension 9 ..
    + infer_planning (world model planner)
    .. Extension 7 ..
    + infer_maml (meta-adapted PyTorch policy)
    --flags--
    --hierarchical / --transfer / --player-id
    --irl / --planning / --maml
  }
}

