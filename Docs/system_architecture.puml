' EXTENSION 8: IRL PLAYER MODELING
' ============================================================================
package "IRL Player Modeling (Ext 8)" <<Rectangle>> #E8EAF6 {
  class MaxEntIRL <<(P,#3F51B5)>> {
    theta : ndarray  {20-dim reward weights}
    feature_dim : int = 20
    num_actions : int = 5
    lr : float = 0.01
    n_iterations : int = 200
    --
    + train(trajectories) : dict {metrics}
    + predict_action_distribution(obs) : ndarray {5-dim P(a|s)}
    + get_reward_weights() : ndarray
    + save(path) / load(path)
    --
    - _compute_feature_expectations(trajectories) : ndarray
    - _build_transition_model(trajectories)
    - _soft_q_values(features) : ndarray
    .. Algorithm ..
    MaxEnt IRL (Ziebart et al. 2008)
    R(s) = theta^T * phi(s)
  }

  class "irl_feature_engineering" as IRLFeatures <<(P,#3F51B5) Module>> {
    + obs_to_irl_features(obs_17dim) : ndarray {20-dim}
    + batch_obs_to_features(obs_batch) : ndarray {vectorized}
    + trajectories_from_replays(episodes) : list[list[tuple]]
    .. Derived Features ..
    hp_difference, is_close_range, is_mid_range,
    is_far_range, is_hero_low_hp, is_attacking_close,
    retreating, hp_advantage, profile_dims[4]
  }
}

